Options -Indexes
RewriteEngine On

# CORS para el frontend
Header always set Access-Control-Allow-Origin "*"
Header always set Access-Control-Allow-Methods "GET, POST, PATCH, DELETE, OPTIONS"
Header always set Access-Control-Allow-Headers "Content-Type, Authorization, apikey"

# Responder OPTIONS inmediatamente
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^ - [R=204,L]

# amelia_bridge.php y robots.txt se sirven directo
RewriteRule ^amelia_bridge\.php$ - [L]
RewriteRule ^robots\.txt$ - [L]

# Todo lo demas va al router
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]
